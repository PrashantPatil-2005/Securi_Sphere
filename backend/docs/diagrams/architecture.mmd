graph TB
    subgraph Agents
        A1[Agent Host 1]
        A2[Agent Host N]
    end

    subgraph Ingestion
        LB[Load Balancer]
        API[Securi API]
        VAL[Validation Layer]
        NORM[Normalization Layer]
        ENR[MITRE Enrichment]
    end

    subgraph Processing
        JQ[Job Queue]
        DET[Detection Engine]
        COR[Correlation Engine]
        OFF[Offense Engine]
        SCR[Threat Scoring]
    end

    subgraph Storage
        PG[(PostgreSQL)]
        REDIS[(Redis)]
        ANAL[Analytics Stats]
    end

    subgraph Output
        WS[WebSocket Feed]
        NOTIF[Notifications]
        DASH[Dashboard API]
    end

    A1 --> LB
    A2 --> LB
    LB --> API
    API --> VAL --> NORM --> ENR --> PG
    ENR --> JQ
    JQ --> DET --> COR --> OFF --> SCR
    DET --> PG
    COR --> PG
    OFF --> PG
    SCR --> PG
    JQ --- REDIS
    PG --> ANAL
    DET --> WS
    DET --> NOTIF
    PG --> DASH
