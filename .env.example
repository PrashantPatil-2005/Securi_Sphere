# Copy to .env and fill in values locally. Never commit .env.

POSTGRES_USER=securi
POSTGRES_DB=securi
POSTGRES_PASSWORD=

# Example format (set in your local .env only):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DBNAME
# Optional read replica — see docs/READ_REPLICAS.md
# DATABASE_READ_URL=postgresql+asyncpg://USER:PASSWORD@replica:5432/DBNAME
# Production managed Postgres with TLS in transit:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db.example.com:5432/DBNAME?ssl=require
# At-rest encryption is infrastructure-level — see docs/DB_ENCRYPTION_AT_REST.md
DATABASE_URL=

# Generate a random secret for JWT_SECRET in your local .env
JWT_SECRET=

JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

SERVER_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Frontend build/runtime (set in frontend/.env.local for native dev)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional email/Telegram alerts - see docs/DEPLOYMENT.md
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@securi.local

TELEGRAM_BOT_TOKEN=

REDIS_URL=
JOB_QUEUE_BACKEND=memory
JOB_QUEUE_WORKERS=2
JOB_QUEUE_RUN_WORKERS=true
WS_PUBSUB_BACKEND=memory
ASYNC_EVENT_PIPELINE=true
EVENT_PARTITIONING_ENABLED=false
VIRUSTOTAL_API_KEY=
THREAT_INTEL_FEEDS_ENABLED=true
THREAT_INTEL_FEED_SYNC_MINUTES=60
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
AGENT_MTLS_ENABLED=false
AGENT_MTLS_CA_CERT_PATH=
ALLOW_REGISTRATION=true
ENABLE_SIMULATION=true
EXCLUDE_SIMULATED_FROM_DASHBOARD=false
AGENT_REQUEST_SIGNING=false
OPENSEARCH_URL=
SEARCH_BACKEND=postgres
OPENSEARCH_BULK_SIZE=500
OPENSEARCH_RETENTION_DAYS=90

# Account lockout (brute-force protection)
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# UEBA anomaly detection — see docs/UEBA.md
UEBA_ENABLED=true
UEBA_Z_THRESHOLD=2.5
UEBA_MIN_OBSERVED=5
UEBA_BASELINE_DAYS=7
UEBA_MIN_BASELINE_SAMPLES=3
UEBA_WINDOW_HOURS=24
UEBA_CREATE_ALERTS=true
UEBA_SCAN_INTERVAL_MINUTES=60

# OIDC / SSO (optional — see docs/OIDC_SSO.md)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTO_PROVISION=false
OIDC_DEFAULT_ROLE=analyst
OIDC_PROVIDER_LABEL=SSO
OIDC_SCOPES=openid email profile
# Map IdP group/app-role names to Securi roles (admin|analyst|viewer)
OIDC_GROUPS_CLAIM=groups
OIDC_ROLE_MAP={"Securi-Admins":"admin","Securi-Analysts":"analyst"}
OIDC_SYNC_ROLES_ON_LOGIN=true
OIDC_ALLOWED_EMAIL_DOMAINS=company.com
CROSS_HOST_CORRELATION_INTERVAL_SECONDS=60
TRUSTED_PROXY=false

# Caddy TLS (docker-compose.caddy.yml)
SECURI_DOMAIN=

# AI Assistant (local-first; optional LLM enrichment)
AI_ASSISTANT_ENABLED=true
AI_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DEBUG=true
SQL_ECHO=false
ENVIRONMENT=development
RETENTION_DAYS=90

# Backups — see docs/BACKUP_AUTOMATION.md
BACKUP_ENABLED=true
BACKUP_DIRECTORY=data/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_HOUR=1

# Graceful shutdown — see docs/GRACEFUL_SHUTDOWN.md
SHUTDOWN_GRACE_SECONDS=30

# Circuit breakers — see docs/CIRCUIT_BREAKERS.md
CIRCUIT_BREAKERS_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# Request timeouts — see docs/REQUEST_TIMEOUTS.md
REQUEST_TIMEOUT_ENABLED=true
REQUEST_TIMEOUT_SECONDS=60
REQUEST_TIMEOUT_AGENT_SECONDS=120
REQUEST_TIMEOUT_EXPORT_SECONDS=300
OUTBOUND_HTTP_TIMEOUT_SECONDS=30
OUTBOUND_HTTP_TIMEOUT_SHORT_SECONDS=15

# Database connection pool — see docs/CONNECTION_POOLING.md
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
READ_REPLICA_LAG_WARN_SECONDS=30

# Analytics materialized views — see docs/MATERIALIZED_VIEWS_ANALYTICS.md
ANALYTICS_MATERIALIZED_VIEWS_ENABLED=true
ANALYTICS_MV_REFRESH_INTERVAL_MINUTES=60

# Pilot demo seed (creates demo@securi.local / Demo1234! admin when true)
DEMO_MODE=false

# Product telemetry and dynamic UX feature flags
TELEMETRY_ENABLED=true
DYNAMIC_UX_ENABLED=true
UX_ACTIVATION_COACH_ENABLED=true
UX_LIVE_SIMULATION_ENABLED=true
UX_ENROLLMENT_HANDSHAKE_ENABLED=true
UX_GUIDED_TRIAGE_ENABLED=true
UX_DASHBOARD_VITALITY_ENABLED=true
UX_ADMIN_OPS_CONSOLE_ENABLED=true
