# Copy to .env and fill in values locally. Never commit .env.

POSTGRES_USER=securi
POSTGRES_DB=securi
POSTGRES_PASSWORD=

# Example format (set in your local .env only):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DBNAME
DATABASE_URL=

# Generate a random secret for JWT_SECRET in your local .env
JWT_SECRET=

JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

SERVER_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Optional email/Telegram alerts - see docs/DEPLOYMENT.md

TELEGRAM_BOT_TOKEN=

REDIS_URL=
JOB_QUEUE_BACKEND=memory
JOB_QUEUE_WORKERS=2
JOB_QUEUE_RUN_WORKERS=true
WS_PUBSUB_BACKEND=memory
EVENT_PARTITIONING_ENABLED=false
VIRUSTOTAL_API_KEY=
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
AGENT_MTLS_ENABLED=false
AGENT_MTLS_CA_CERT_PATH=
ALLOW_REGISTRATION=true
ENABLE_SIMULATION=true
EXCLUDE_SIMULATED_FROM_DASHBOARD=true
AGENT_REQUEST_SIGNING=false
OPENSEARCH_URL=
SEARCH_BACKEND=postgres
CROSS_HOST_CORRELATION_INTERVAL_SECONDS=60
TRUSTED_PROXY=false

# AI Assistant (local-first; optional LLM enrichment)
AI_ASSISTANT_ENABLED=true
AI_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DEBUG=true
SQL_ECHO=false
ENVIRONMENT=development
RETENTION_DAYS=90
